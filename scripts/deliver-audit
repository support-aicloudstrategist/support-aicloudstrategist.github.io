#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const LEADS_DIR = '/home/OpenClaw/.openclaw/workspace/reports/leads';
const PACK_DIR = '/home/OpenClaw/.openclaw/workspace/reports/approval-packs';
function arg(n){ const i=process.argv.indexOf(`--${n}`); return i>=0 ? process.argv[i+1] : ''; }
function flag(n){ return process.argv.includes(`--${n}`); }
function words(s){ return String(s||'').replace(/\s+/g,' ').trim(); }
function requireFile(p, label){ if(!fs.existsSync(p)){ console.error(`Missing ${label}: ${p}`); process.exit(2); } }
function main(){
  const leadId = arg('lead_id') || process.argv[2];
  if(!leadId){ console.error('Usage: scripts/deliver-audit --lead_id <lead_id> [--approved] [--dry-run]'); process.exit(2); }
  fs.mkdirSync(PACK_DIR,{recursive:true}); fs.mkdirSync(LEADS_DIR,{recursive:true});
  const leadPath = path.join(LEADS_DIR, `${leadId}.json`);
  const pdfPath = `/tmp/audits/${leadId}.pdf`;
  const auditJsonPath = `/tmp/audits/${leadId}.json`;
  requireFile(leadPath,'lead json'); requireFile(pdfPath,'audit pdf');
  const lead = JSON.parse(fs.readFileSync(leadPath,'utf8'));
  const audit = fs.existsSync(auditJsonPath) ? JSON.parse(fs.readFileSync(auditJsonPath,'utf8')) : {};
  const bullets = (audit.summary || [
    `Website reviewed: ${lead.website_url || lead.website || 'not provided'}`,
    'Founder manual review required before delivery.',
    'Lead-loss estimate remains insufficient public data until approved.'
  ]).slice(0,5);
  const email = `Subject: Your Lost-Lead Audit for ${lead.business_name}\n\nHi ${lead.full_name || 'there'},\n\nYour Lost-Lead Audit is ready for review. I’ve attached the PDF with the main website, WhatsApp/contact visibility, mobile, trust and DPDP-readiness observations we could verify publicly.\n\nPlease read the first-page summary first. If you want, reply with “REVIEW” and we’ll help you prioritise the fastest fixes.\n\nWarmly,\nAnushka Bhattacharya\nDirector, AICloudStrategist`;
  const whatsapp = `Hi ${lead.full_name || 'there'}, Anushka from AICloudStrategist here. Your Lost-Lead Audit for ${lead.business_name} is ready. I’m sharing the PDF on email now. Please check the summary first, and reply REVIEW if you want help prioritising the fixes.`;
  const pack = `# Audit delivery approval pack — ${leadId}\n\nDecision sought: APPROVE / REJECT / EDIT\n\n## Prospect\n- Business: ${lead.business_name}\n- Contact: ${lead.full_name || 'not provided'}\n- Email: ${lead.prospect_email || lead.email || 'not provided'}\n- WhatsApp: ${lead.whatsapp_number || 'not provided'}\n- Website: ${lead.website_url || lead.website || 'not provided'}\n- Vertical: ${lead.vertical || 'not provided'}\n\n## Audit summary excerpt\n${bullets.map(b=>`- ${b}`).join('\n')}\n\n## Draft cover email\n${email}\n\n## Draft WhatsApp message\n${whatsapp}\n\n## Attachment\n${pdfPath} (${fs.statSync(pdfPath).size} bytes)\n`;
  const packPath = path.join(PACK_DIR, `audit-delivery-${leadId}.md`);
  fs.writeFileSync(packPath, pack);
  if(!flag('approved')) { console.log(`Approval pack saved: ${packPath}\nNo send performed. Founder approval required.`); return; }
  if(flag('dry-run') || process.env.AICS_DRY_RUN === '1') { console.log(`DRY RUN approved send: would email ${lead.prospect_email || lead.email} with ${pdfPath}; would WhatsApp ${lead.whatsapp_number}.`); return; }
  console.error('Approved real send is intentionally not enabled in this repository script without configured M365 + WhatsApp delivery adapter. No outreach sent.');
  process.exit(4);
}
main();
