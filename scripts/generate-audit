#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

const ROOT = path.resolve(__dirname, '..');
const TEMPLATE = path.join(ROOT, 'assets/audit/lost-lead-audit-template.pdf');
const OUT_DIR = '/tmp/audits';

function arg(name, fallback='') {
  const ix = process.argv.indexOf(`--${name}`);
  if (ix >= 0 && process.argv[ix + 1]) return process.argv[ix + 1];
  return fallback;
}
function esc(s){ return String(s ?? '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
function has(re, html){ return re.test(html || ''); }
function textSnippet(html){ return (html||'').replace(/<script[\s\S]*?<\/script>/gi,' ').replace(/<style[\s\S]*?<\/style>/gi,' ').replace(/<[^>]+>/g,' ').replace(/\s+/g,' ').trim().slice(0,400); }
function scoreFinding(ok, good, bad){ return ok ? {status:'pass', finding:good} : {status:'review', finding:bad}; }
async function main(){
  let input = {};
  const jsonFile = arg('json');
  if (jsonFile) input = JSON.parse(fs.readFileSync(jsonFile,'utf8'));
  for (const key of ['lead_id','business_name','website_url','whatsapp_number','vertical']) input[key] = arg(key, input[key]);
  if (!input.lead_id || !input.business_name || !input.website_url || !input.vertical) {
    console.error('Missing required args: --lead_id --business_name --website_url --vertical [--whatsapp_number] or --json file');
    process.exit(2);
  }
  if (!fs.existsSync(TEMPLATE)) {
    console.error(`Missing template: ${TEMPLATE}. PR #9 must provide assets/audit/lost-lead-audit-template.pdf`);
    process.exit(3);
  }
  const started = Date.now();
  let response, html = '', fetchError = '';
  try {
    response = await fetch(input.website_url, { redirect:'follow', headers:{'User-Agent':'AICloudStrategist AuditBot/1.0'} });
    html = await response.text();
  } catch(e) { fetchError = e.message; }
  const loadMs = Date.now() - started;
  const url = new URL(input.website_url);
  const checks = {
    https: scoreFinding(url.protocol === 'https:', 'HTTPS is enabled.', 'Website is not loaded over HTTPS.'),
    mobile_responsive: scoreFinding(has(/<meta[^>]+name=["']viewport["']/i, html), 'Viewport meta tag found.', 'No viewport meta tag found in public HTML.'),
    page_load_time: { status: loadMs <= 3000 ? 'pass' : 'review', finding: `${loadMs} ms HTML fetch time (${response?.status || fetchError || 'no response'}).` },
    contact_visibility: scoreFinding(has(/tel:|mailto:|contact|phone|call|whatsapp|appointment|book/i, html), 'Contact/call signals visible in public HTML.', 'Contact/call signals not obvious in public HTML.'),
    whatsapp_cta: scoreFinding(has(/wa\.me|api\.whatsapp|whatsapp/i, html), 'WhatsApp CTA/reference found.', 'No WhatsApp CTA/reference found in public HTML.'),
    privacy_policy: scoreFinding(has(/privacy\s+policy|href=["'][^"']*privacy/i, html), 'Privacy policy signal found.', 'Privacy policy link not obvious in public HTML.'),
    cookie_banner: scoreFinding(has(/cookie|consent/i, html), 'Cookie/consent signal found.', 'Cookie/consent banner not obvious in public HTML.'),
    dpdp_pii_consent: scoreFinding(!has(/<form[\s\S]*?(name|email|phone|mobile|whatsapp)[\s\S]*?<\/form>/i, html) || has(/consent|privacy/i, html), 'PII collection appears to have consent/privacy context or no public PII form found.', 'Possible PII form found without obvious consent/privacy wording in public HTML.'),
  };
  const manualLeadEstimate = 'Insufficient public data — founder manual review required';
  const summary = [
    `Website: ${input.website_url}`,
    `HTTPS: ${checks.https.finding}`,
    `Mobile: ${checks.mobile_responsive.finding}`,
    `Load: ${checks.page_load_time.finding}`,
    `WhatsApp CTA: ${checks.whatsapp_cta.finding}`,
    `DPDP: ${checks.dpdp_pii_consent.finding}`,
    `Leads lost/month: ${manualLeadEstimate}`
  ];
  fs.mkdirSync(OUT_DIR, {recursive:true});
  const pdfPath = path.join(OUT_DIR, `${input.lead_id}.pdf`);
  const htmlPath = path.join(OUT_DIR, `${input.lead_id}.html`);
  const resultJsonPath = path.join(OUT_DIR, `${input.lead_id}.json`);
  const reportHtml = `<!doctype html><html><head><meta charset="utf-8"><title>Lost-Lead Audit - ${esc(input.business_name)}</title><style>body{font-family:Arial,sans-serif;color:#13233f;margin:42px}.cover{border:2px solid #13233f;padding:28px;margin-bottom:22px}h1{font-size:30px}h2{margin-top:26px}.grid{display:grid;grid-template-columns:1fr 2fr;gap:8px 18px}.status-pass{color:#106b3c}.status-review{color:#9a5b00}.small{color:#5d6678;font-size:12px}</style></head><body><div class="cover"><p class="small">Filled from template: ${esc(path.relative(ROOT,TEMPLATE))}</p><h1>Lost-Lead Audit</h1><h2>${esc(input.business_name)}</h2><p>${esc(input.vertical)} • ${esc(input.website_url)}</p><p><strong>Lead ID:</strong> ${esc(input.lead_id)}</p></div><h2>Public website checks</h2><div class="grid">${Object.entries(checks).map(([k,v])=>`<strong>${esc(k.replace(/_/g,' '))}</strong><span class="status-${v.status}">${esc(v.finding)}</span>`).join('')}</div><h2>Estimated leads lost/month</h2><p>${esc(manualLeadEstimate)}</p><h2>Founder review notes</h2><p>This PDF is pre-filled from public website checks only. Validate assumptions before approving delivery.</p><h2>Public HTML excerpt</h2><p>${esc(textSnippet(html) || fetchError || 'No HTML captured.')}</p></body></html>`;
  fs.writeFileSync(htmlPath, reportHtml);
  const chrome = spawnSync('google-chrome', ['--headless','--disable-gpu','--no-sandbox',`--print-to-pdf=${pdfPath}`, `file://${htmlPath}`], {encoding:'utf8'});
  if (chrome.status !== 0 || !fs.existsSync(pdfPath)) {
    fs.writeFileSync(pdfPath, Buffer.from(`%PDF-1.4\n% Audit generation failed; see ${htmlPath}\n%%EOF\n`));
  }
  const result = { lead: input, fetched: { status: response?.status || null, final_url: response?.url || null, load_ms: loadMs, error: fetchError || null }, checks, lead_loss_estimate: manualLeadEstimate, output_pdf: pdfPath, output_pdf_bytes: fs.statSync(pdfPath).size, html_debug: htmlPath, template_pdf: TEMPLATE, summary };
  fs.writeFileSync(resultJsonPath, JSON.stringify(result,null,2));
  console.log(JSON.stringify(result,null,2));
}
main().catch(e=>{ console.error(e.stack || e.message); process.exit(1); });
